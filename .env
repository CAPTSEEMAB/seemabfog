# ─── Smart Traffic IoT Platform — Shared Environment Config ───
# This file is referenced by docker-compose.yml via env_file directive.
# Override any value by setting the env var directly in docker-compose or shell.

# ── AWS / LocalStack ──
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localstack:4566

# ── SQS Queue URLs (LocalStack format) ──
AGGREGATES_QUEUE_URL=http://localstack:4566/000000000000/smart-traffic-aggregates-queue.fifo
EVENTS_QUEUE_URL=http://localstack:4566/000000000000/smart-traffic-events-queue.fifo

# ── SQS Queue Names (used for queue creation) ──
AGGREGATES_QUEUE_NAME=smart-traffic-aggregates-queue.fifo
EVENTS_QUEUE_NAME=smart-traffic-events-queue.fifo

# ── DynamoDB Table Names ──
AGGREGATES_TABLE_NAME=smart-traffic-aggregates
EVENTS_TABLE_NAME=smart-traffic-events
KPIS_TABLE_NAME=smart-traffic-kpis

# ── Fog Node Thresholds ──
SPEED_THRESHOLD=80
CONGESTION_INDEX_THRESHOLD=2.0
SPEED_DROP_PERCENTAGE=40

# ── Fog Node Timing ──
WINDOW_SIZE_SEC=10
AGGREGATE_INTERVAL_SEC=10
DEDUP_CACHE_TTL_SEC=10

# ── Fog Node Retry / Backoff ──
MAX_RETRIES=3
BACKOFF_BASE=0.5
BACKOFF_MAX=10
BACKOFF_JITTER=0.25

# ── Fog Validation Bounds (JSON) ──
SENSOR_BOUNDS={"vehicle_speed":[0,160],"vehicle_count":[0,500],"pollution_pm25":[0,500],"ambient_light":[0,100000]}

# ── Cloud Consumer ──
POLL_INTERVAL_SEC=2
SQS_BATCH_SIZE=10
API_PORT=5000
SQS_LONG_POLL_SEC=10
MESSAGE_RETENTION_PERIOD=345600

# ── Safety Score Weights (shared between Lambda and local consumer) ──
SAFETY_SPEEDING_WEIGHT=5
SAFETY_INCIDENT_WEIGHT=10
SAFETY_MAX_PENALTY=100
SAFETY_MAX_SCORE=100

# ── Dashboard ──
REACT_APP_FOG_A=http://localhost:8001
REACT_APP_FOG_B=http://localhost:8002
REACT_APP_API_ENDPOINT=http://localhost:5000/api
REACT_APP_POLL_INTERVAL_MS=5000
# Host port for dashboard (change if 3000 in use)
DASHBOARD_HOST_PORT=3001
